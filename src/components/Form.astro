---
import { Image } from 'astro:assets';
import Input from './Input.astro';
import Tip from './Tip.astro';
import iconDolar from '../assets/icon-dollar.svg';
import iconPeople from '../assets/icon-person.svg';
---

<section>
    <Input label="Bill" iconSrc={iconDolar} class="inputBill" />
    <Tip />
    <Input label="Number of People" iconSrc={iconPeople} class="inputPeople" />
</section>

<style>
    section {
        background-color: white;
        padding: 1.3rem;
        border-radius: 15px;
    }
</style>
